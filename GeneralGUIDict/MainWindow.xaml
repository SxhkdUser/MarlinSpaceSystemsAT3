<Window x:Class="GeneralGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeneralGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        >
    <Grid>
        <ListBox x:Name="RawListBox" HorizontalAlignment="Left" Height="400" VerticalAlignment="Top" Width="294"  Focusable="False" IsHitTestVisible="True" Margin="106,10,0,0" SelectionChanged="Selected_Raw"/>
        <ListBox x:Name="SortedListBox" HorizontalAlignment="Left" Height="352" Margin="400,58,0,0" VerticalAlignment="Top" Width="371" RenderTransformOrigin="0.5,0.5">
            <ListBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0" AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0" X="0"/>
                </TransformGroup>
            </ListBox.RenderTransform>
        </ListBox>
        <TextBox x:Name="NameInputTextBox" HorizontalAlignment="Left" Height="19" Margin="474,34,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="287" TextChanged="NameInputTextBox_TextChanged"/>
        <TextBox x:Name="IdInputTextBox" HorizontalAlignment="Left" Height="19" Margin="474,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="287" TextChanged="IdInputTextBox_TextChanged"/>
        <Label Content="StaffName" HorizontalAlignment="Left" Height="24" Margin="405,26,0,0" VerticalAlignment="Top" Width="64"/>
        <Label Content="StaffID" HorizontalAlignment="Left" Height="24" Margin="421,5,0,0" VerticalAlignment="Top" Width="48"/>
        <Label Content="Hotkeys:&#xD;&#xA;N + Ctrl: Clear&#xD;&#xA; and focus &#xD;&#xA; staff name&#xD;&#xA;S + Ctrl: Clear&#xD;&#xA; and focus &#xD;&#xA; staff id&#xD;&#xA;K + Tab: Display&#xD;&#xA; Selected item&#xD;&#xA; in textboxes&#xD;&#xA;A + Alt: Display&#xD;&#xA; Admin&#xD;&#xA; Window &#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" HorizontalAlignment="Left" Height="400" Margin="5,10,0,0" VerticalAlignment="Top" Width="96"/>
    </Grid>

</Window>
    
