<Window x:Class="GeneralGUI.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Closed="Admin_Closed"
        KeyDown="AdminWindow_KeyDown"
        Title="Admin">
    <Grid>
        <ListBox x:Name="RawListBox" HorizontalAlignment="Left" Height="400" VerticalAlignment="Top" Width="385"  Focusable="False" IsHitTestVisible="False" Margin="10,10,0,0" Visibility="Hidden"/>
        <ListBox x:Name="SortedListBox" HorizontalAlignment="Left" Height="352" Margin="400,58,0,0" VerticalAlignment="Top" Width="390" RenderTransformOrigin="0.5,0.5" Visibility="Hidden">
            <ListBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0" AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0" X="0"/>
                </TransformGroup>
            </ListBox.RenderTransform>
        </ListBox>
        <TextBox x:Name="NameInputTextBox" HorizontalAlignment="Center" Height="21" Margin="0,176,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="98" IsReadOnly="True" />
        <TextBox x:Name="IdInputTextBox" HorizontalAlignment="Center" Height="21" Margin="0,149,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="98" IsReadOnly="True"/>
        <Label Content="StaffName" HorizontalAlignment="Left" Height="27" Margin="264,167,0,0" VerticalAlignment="Top" Width="77"/>
        <Label Content="StaffID" HorizontalAlignment="Left" Height="27" Margin="294,143,0,0" VerticalAlignment="Top" Width="47"/>
        <Button  HorizontalAlignment="Left" Height="48" Margin="449,146,0,0" VerticalAlignment="Top" Width="55" RenderTransformOrigin="0.539,0.696" x:Name="ChangeBtn" Click="ChangeBtn_Click"  Content="Change"/>
        <Button  HorizontalAlignment="Center" Height="32" Margin="0,210,0,0" VerticalAlignment="Top" Width="98" RenderTransformOrigin="0.539,0.696" x:Name="DeleteBtn" Click="DeleteBtn_Click"  Content="Delete"/>
        <Button  HorizontalAlignment="Center" Height="32" Margin="0,112,0,0" VerticalAlignment="Top" Width="98" RenderTransformOrigin="0.539,0.696" x:Name="AddBtn_Copy" Click="AddBtn_Click"  Content="Add"/>
    </Grid>
</Window>
