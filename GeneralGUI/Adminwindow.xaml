<Window x:Class="GeneralGUI.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Title="Admin">
    <Grid>
        <ListBox x:Name="RawListBox" HorizontalAlignment="Left" Height="400" VerticalAlignment="Top" Width="385"  Focusable="False" IsHitTestVisible="False" Margin="10,10,0,0" Visibility="Hidden"/>
        <ListBox x:Name="SortedListBox" HorizontalAlignment="Left" Height="352" Margin="400,58,0,0" VerticalAlignment="Top" Width="390" RenderTransformOrigin="0.5,0.5" Visibility="Hidden">
            <ListBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0" AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0" X="0"/>
                </TransformGroup>
            </ListBox.RenderTransform>
        </ListBox>
        <TextBox x:Name="NameInputTextBox" HorizontalAlignment="Left" Height="21" Margin="252,184,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="98" IsReadOnly="True" />
        <TextBox x:Name="IdInputTextBox" HorizontalAlignment="Left" Height="21" Margin="252,157,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="98" IsReadOnly="True"/>
        <Label Content="StaffName" HorizontalAlignment="Left" Height="27" Margin="184,175,0,0" VerticalAlignment="Top" Width="63"/>
        <Label Content="StaffID" HorizontalAlignment="Left" Height="27" Margin="200,151,0,0" VerticalAlignment="Top" Width="47"/>
        <TextBox x:Name="NameChangeInputTextBox" HorizontalAlignment="Left" Height="21" Margin="438,184,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="99" />
        <TextBox x:Name="IdChangeInputTextBox_Copy" HorizontalAlignment="Left" Height="21" Margin="438,157,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="99" />
        <Label Content="NewStaffName" HorizontalAlignment="Left" Height="27" Margin="350,178,0,0" VerticalAlignment="Top" Width="88"/>
        <Label Content="NewStaffID" HorizontalAlignment="Left" Height="27" Margin="350,155,0,0" VerticalAlignment="Top" Width="70"/>
        <Button  HorizontalAlignment="Left" Height="33" Margin="439,217,0,0" VerticalAlignment="Top" Width="98" RenderTransformOrigin="0.539,0.696" x:Name="ChangeBtn" Click="ChangeBtn_Click"  Content="Change"/>
        <Button  HorizontalAlignment="Left" Height="32" Margin="252,218,0,0" VerticalAlignment="Top" Width="98" RenderTransformOrigin="0.539,0.696" x:Name="DeleteBtn" Click="DeleteBtn_Click"  Content="Delete"/>
        <Button  HorizontalAlignment="Left" Height="32" Margin="356,218,0,0" VerticalAlignment="Top" Width="78" RenderTransformOrigin="0.539,0.696" x:Name="AddBtn_Copy" Click="AddBtn_Click"  Content="Add"/>
    </Grid>
</Window>
